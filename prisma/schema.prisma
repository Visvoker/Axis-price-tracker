generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum GroupRole {
  ADMIN
  MEMBER
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]

  memberships    GroupMember[]
  ownedGroups    Group[]       @relation("GroupOwner")
  priceRecords   PriceRecord[] @relation("PriceRecordCreatedBy")
  createdInvites GroupInvite[] @relation("GroupInviteCreatedBy")
}

model Group {
  id         String   @id @default(cuid())
  name       String
  maxMembers Int      @default(10)
  ownerId    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  owner   User?         @relation("GroupOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  members GroupMember[]
  invites GroupInvite[]
  items   Item[]

  @@index([ownerId])
}

model GroupMember {
  id        String    @id @default(cuid())
  userId    String
  groupId   String
  role      GroupRole @default(MEMBER)
  createdAt DateTime  @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId])
  @@index([groupId])
}

model GroupInvite {
  id          String    @id @default(cuid())
  code        String    @unique
  groupId     String
  createdById String?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())

  group     Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  createdBy User? @relation("GroupInviteCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([groupId])
  @@index([createdById])
}

model Item {
  id        String   @id @default(cuid())
  name      String
  category  String?
  note      String?
  groupId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  group  Group         @relation(fields: [groupId], references: [id], onDelete: Cascade)
  prices PriceRecord[]

  @@unique([groupId, name])
  @@index([groupId])
}

model PriceRecord {
  id          String   @id @default(cuid())
  itemId      String
  createdById String
  price       Decimal  @db.Decimal(12, 2)
  createdAt   DateTime @default(now())

  item      Item @relation(fields: [itemId], references: [id], onDelete: Cascade)
  createdBy User @relation("PriceRecordCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([itemId, createdAt])
}

// NextAuth
model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
  @@index([userId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([sessionToken])
  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}
